# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Security - Password Hashing
# Número de salt rounds para bcrypt (recomendado: 10-12)
# Valores más altos = más seguro pero más lento
# 10 rounds = ~10 hashes/segundo, 12 rounds = ~5 hashes/segundo
BCRYPT_SALT_ROUNDS=12

# Azure Cosmos DB (Para implementación futura)
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-key
# COSMOS_DATABASE=petfinder-db

# Azure Blob Storage
# Mantén estos secretos fuera del repositorio.
# Usa variables de entorno del App Service / Key Vault para producción.
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
# Variable solicitada por HU-65
AZURE_STORAGE_CONTAINER=pet-images
# Alias compatible hacia atras
AZURE_STORAGE_CONTAINER_NAME=pet-images

# Opcional para URLs firmadas (recomendado)
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_USE_SIGNED_URLS=true
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60
AZURE_STORAGE_MAX_FILE_SIZE_MB=5

# CORS
# Desarrollo local
# CORS_ORIGINS=http://localhost:4200,http://localhost:3001,http://localhost:5173
# Producción Azure (agregar URLs del frontend desplegado)
CORS_ORIGINS=https://kind-water-085d48310.2.azurestaticapps.net,http://localhost:5173

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ────────────────────────────────────────────────
# Email (Nodemailer + Gmail SMTP)
# ────────────────────────────────────────────────
# Pasos para configurar con Gmail:
#   1. Activa la verificación en dos pasos en tu cuenta Gmail.
#   2. Ve a Cuenta de Google → Seguridad → Contraseñas de aplicaciones.
#   3. Crea una contraseña de aplicación (selecciona "Correo" + "Windows/Mac").
#   4. Usa esa contraseña de 16 dígitos como EMAIL_PASSWORD (sin espacios).
#   5. EMAIL_USER debe ser tu dirección Gmail completa.
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASSWORD=tu-app-password-de-16-digitos
EMAIL_FROM=PetFinder <tu-correo@gmail.com>

# URL del frontend (para construir los enlaces en los correos)
FRONTEND_URL=https://kind-water-085d48310.2.azurestaticapps.net
